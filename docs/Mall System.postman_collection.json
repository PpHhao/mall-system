      "item": [
        {
          "name": "1. 管理员登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login Successful\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "if (jsonData.data) {\r",
                  "    if (jsonData.data.accessToken) {\r",
                  "        pm.environment.set(\"token\", jsonData.data.accessToken);\r",
                  "        console.log(\"Access Token 已更新\");\r",
                  "    }\r",
                  "\r",
                  "    if (jsonData.data.refreshToken) {\r",
                  "        pm.environment.set(\"refreshToken\", jsonData.data.refreshToken); // 存入变量\r",
                  "        console.log(\"Refresh Token 已保存\");\r",
                  "    }\r",
                  "} else {\r",
                  "    console.error(\"Token提取失败\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"{{adminUser}}\",\r\n    \"password\": \"{{adminPass}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
